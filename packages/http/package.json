    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@mantlejs/mantle": "^0.0.1"
  },
  "description": "Zero-dependency HTTP transport adapter for Mantle JS (Node.js handler + Fetch API handler)",
  "license": "MIT",
  "keywords": [
    "mantle",
    "http",
    "transport",
    "edge",
    "cloudflare-workers"
