{
  "name": "@mantlejs/auth-local",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mantle/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "auth-local"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "description": "Local (email + password) authentication strategy for Mantle JS",
  "license": "MIT",
  "keywords": [
    "mantle",
    "auth",
    "local",
    "password",
    "argon2"
  ],
  "peerDependencies": {
    "@mantlejs/mantle": "^0.0.1",
    "@mantlejs/auth": "^0.0.1",
    "@node-rs/argon2": "^2.0.0"
  }
}
