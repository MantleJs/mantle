{
  "name": "@mantlejs/postgresql",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mantle/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "postgresql"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "description": "PostgreSQL adapter for Mantle JS via Knex.js",
  "license": "MIT",
  "keywords": [
    "mantle",
    "postgresql",
    "knex",
    "database"
  ],
  "peerDependencies": {
    "@mantlejs/core": "^0.1.0",
    "knex": "^3.0.0",
    "pg": "^8.0.0"
  }
}
