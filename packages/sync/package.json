{
  "name": "@mantlejs/sync",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mantle/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "sync"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "description": "Cross-instance event sync for Mantle JS — broadcasts service events across multiple application instances via Redis or Supabase Realtime",
  "license": "MIT",
  "keywords": [
    "mantle",
    "sync",
    "realtime",
    "redis",
    "pubsub",
    "events",
    "typescript"
  ],
  "peerDependencies": {
    "@mantlejs/mantle": "^0.0.1",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
