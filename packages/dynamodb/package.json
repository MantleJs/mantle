  "license": "MIT",
  "keywords": [
    "mantle",
    "dynamodb",
    "aws",
    "nosql",
    "database",
    "repository"
  ],
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/util-dynamodb": "^3.0.0",
    "@mantlejs/mantle": "^0.1.0"
  }
}
