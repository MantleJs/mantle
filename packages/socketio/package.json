  "keywords": [
    "mantle",
    "socketio",
    "websocket",
    "realtime"
  ],
  "dependencies": {
    "socket.io": "^4.8.1",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@mantlejs/core": "^0.0.1"
  }
}
