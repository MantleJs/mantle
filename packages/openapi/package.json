{
  "name": "@mantlejs/openapi",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mantle/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "openapi"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@mantlejs/mantle": "^0.0.1"
  },
  "description": "OpenAPI document generation for Mantle JS services",
  "license": "MIT",
  "keywords": [
    "mantle",
    "openapi",
    "swagger",
    "documentation"
  ]
}
